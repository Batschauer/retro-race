# Local Postgres (docker-compose) or Neon in production
DATABASE_URL="postgresql://retro:retro@localhost:5432/retro_race"

# Required for `docker compose up` (app service). Copy to `.env` and replace with strong secrets.
# Single shared admin password (compared with timing-safe equality in app code)
ADMIN_PASSWORD="your-strong-unique-password"

# Min 16 chars — signs the admin session JWT (e.g. openssl rand -hex 32)
ADMIN_SESSION_SECRET="paste-output-of-openssl-rand-hex-32-here"
